# ── Mimo environment ────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in the values you need.

# Public site URL (used for SEO / Open Graph)
VITE_SITE_URL=http://localhost:5173

# ── Natural voice (Azerbaijani + English) ───────────────────────────
# Mimo speaks with Azure Neural TTS — az-AZ-BanuNeural is a genuinely
# natural Azerbaijani voice. Without these keys Mimo falls back to the
# browser's robotic voice (which usually has no Azerbaijani at all).
#
# How to get a free key (Azure free tier = 500,000 chars/month):
#   1. portal.azure.com → Create resource → "Speech" (Cognitive Services)
#   2. Pick a region (e.g. westeurope) and the Free F0 pricing tier
#   3. Copy Key 1 and the Region into the two lines below
#   4. Run the voice server alongside the site:  npm run tts
#
AZURE_SPEECH_REGION=
AZURE_SPEECH_KEY=

# Optional voice overrides
# AZURE_SPEECH_VOICE_AZ=az-AZ-BanuNeural   # or az-AZ-BabekNeural (male)
# AZURE_SPEECH_VOICE_EN=en-US-JennyNeural
# TTS_PORT=8787

# Force a TTS mode in the browser app (auto | browser)
# VITE_MIMO_TTS_MODE=auto
# VITE_MIMO_TTS_ENDPOINT=/api/tts

# ── Supabase: contact form + waitlist + interaction tracking + admin ─
# These power the contact/early-access forms and the admin panel at /#admin.
# The anon key is browser-safe — all access is gated by Row-Level Security.
#
# Setup:
#   1. Create a free project at https://supabase.com
#   2. SQL Editor → run website/supabase/schema.sql
#   3. Authentication → Users → add user (Auto Confirm):
#        email = mimoadmin@mimorobot.online   password = Ceyhun1968@
#   4. Project Settings → API → copy the URL + anon public key below
#
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# The admin login takes a username; it's mapped to <username>@<domain> for
# Supabase Auth. Change this if you create the admin user on another domain.
# VITE_ADMIN_EMAIL_DOMAIN=mimorobot.online
