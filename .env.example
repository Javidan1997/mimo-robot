GODADDY_API_KEY=your_godaddy_api_key
GODADDY_API_SECRET=your_godaddy_api_secret
GODADDY_API_BASE=https://api.godaddy.com
GODADDY_DOMAIN=mimorobot.online

# Optional Mimo neural voice proxy. Keep provider keys server-side; never
# expose them in frontend code. Edge TTS uses the local Python edge-tts package.
TTS_PROVIDER=edge
EDGE_TTS_VOICE_AZ=az-AZ-BabekNeural
EDGE_TTS_VOICE_EN=en-US-AriaNeural
EDGE_TTS_RATE_AZ=-4%
EDGE_TTS_RATE_EN=-3%

# ElevenLabs is available if TTS_PROVIDER=elevenlabs.
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_my_voices_voice_id
ELEVENLABS_VOICE_ID_AZ=your_azerbaijani_voice_id
ELEVENLABS_VOICE_ID_EN=your_english_voice_id
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Azure is still available if TTS_PROVIDER=azure.
AZURE_SPEECH_REGION=your_azure_speech_region
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_VOICE_AZ=az-AZ-BanuNeural
AZURE_SPEECH_VOICE_EN=en-US-JennyNeural
TTS_PORT=8787
